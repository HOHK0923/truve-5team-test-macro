# ============================================================
# Truve 매크로 수집기 - 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# 대상 프론트엔드 URL
TRUVE_BASE_URL=https://front-nu-tawny.vercel.app

# 테스트 계정 (JSON 배열 형식)
# 예: [{"email":"a@test.com","password":"Pass1!"}]
TRUVE_TEST_ACCOUNTS=

# 대상 공연 / 회차 ID
TRUVE_SHOW_ID=1
TRUVE_SCHEDULE_ID=1
